<!DOCTYPE html>
<html lang="en">

    <head>
        <meta charset="UTF-8" />
        <style>
            body {
                margin: 0;
                padding: 40px 0;
                /* Add some breathing room around the email */
                font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
                background-color: #ffffff;
                color: #333333;
            }

            .container {
                max-width: 600px;
                margin: 0 auto;
                text-align: center;
                /* Center everything by default */
            }

            .header h2 {
                font-size: 24px;
                font-weight: 600;
                margin-bottom: 25px;
            }

            /* The horizontal line from your image */
            .divider {
                border-top: 1px solid #eeeeee;
                margin: 20px 0;
            }

            .message {
                font-size: 16px;
                line-height: 1.6;
                color: #444444;
                text-align: left;
                /* Text inside the message stays left-aligned */
                margin-bottom: 30px;
            }

            .button-wrapper {
                margin: 35px 0;
                text-align: center;
            }

            .button {
                display: inline-block;
                padding: 14px 30px;
                background-color: #00a63d;
                color: #ffffff !important;
                /* Force white color in Gmail */
                text-decoration: none;
                border-radius: 4px;
                font-weight: bold;
                font-size: 16px;
            }

            .footer {
                font-size: 12px;
                color: #999999;
                margin-top: 50px;
            }
        </style>
    </head>

    <body>
        <div class="container">
            <div class="header">
                <h2>Verify Your Email Address</h2>
            </div>

            <div class="divider"></div>

            <div class="message">
                <p>Hello,</p>
                <p>
                    Thank you for registering on our website. To complete your signup process and
                    activate your account, please verify your email address by clicking the button below.
                </p>
            </div>

            <div class="button-wrapper">
                <a href="{{frontendUrl}}/verify/{{token}}"
                   class="button">
                    Verify Your Email
                </a>
            </div>

            <div class="message">
                <p>If you did not initiate this request, you can safely ignore this email.</p>
            </div>

            <div class="footer">
                &copy; 2025 Webelite Builders. All rights reserved.
            </div>
        </div>
    </body>

</html>